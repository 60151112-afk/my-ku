FROM python:3.11-slim

WORKDIR /app

COPY public_site/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY public_site /app/public_site

EXPOSE 8501
HEALTHCHECK CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8501/_stcore/health')"

CMD ["streamlit", "run", "public_site/app.py", "--server.address=0.0.0.0", "--server.port=8501"]
